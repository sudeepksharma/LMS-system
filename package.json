{
  "name": "lms-root",
  "version": "1.0.0",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "everything": "node scripts/dev.mjs",
    "dev:backend": "cd backend && node server.js",
    "dev:frontend": "cd course-compass-main && npm run dev -- --host 0.0.0.0 --port 3000",
    "dev:admin": "cd admin && npm run dev -- --host 0.0.0.0 --port 3001",
    "install:all": "npm install && cd backend && npm install && cd ../course-compass-main && npm install && cd ../admin && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
